# ── Telegram Bot ──────────────────────────────────────────
BOT_TOKEN=your_telegram_bot_token_here
ADMIN_IDS=123456789,987654321

# ── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql://username:password@localhost:5432/dtm_bot

# ── Redis (FSM storage, 50k+ user uchun majburiy) ──────────
# Ubuntu: sudo apt install redis-server && sudo systemctl start redis
# Windows: https://github.com/microsoftarchive/redis/releases
# Docker:  docker run -d -p 6379:6379 redis:alpine
REDIS_URL=redis://localhost:6379/0

# ── Flask Admin Panel ──────────────────────────────────────
SECRET_KEY=change_this_to_random_secret_key_min32chars
FLASK_ENV=production
FLASK_DEBUG=False

# Admin panel login (parolni o'zgartiring!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# ── Test sozlamalari ───────────────────────────────────────
# (config.py da ham mavjud, kerak bo'lsa override qiling)
# TEST_DURATION_MINUTES=180
