# ── Telegram Bot ──────────────────────────────────────────────────────────────
# @BotFather dan oling: /newbot
BOT_TOKEN=your_telegram_bot_token_here

# Bot admin Telegram ID lari (vergul bilan)
ADMIN_IDS=123456789,987654321

# ── Database ───────────────────────────────────────────────────────────────────
# Format: postgresql://foydalanuvchi:parol@host:port/baza_nomi
DATABASE_URL=postgresql://dtm_user:strong_password@localhost:5432/dtm_bot

# ── Redis (FSM uchun — tavsiya etiladi) ───────────────────────────────────────
# Ubuntu:  sudo apt install redis-server && sudo systemctl start redis
# Docker:  docker run -d -p 6379:6379 redis:alpine
# Yo'q bo'lsa — MemoryStorage ishlatiladi (bot restart qilganda FSM o'chadi)
REDIS_URL=redis://localhost:6379/0

# ── Flask Admin Panel ──────────────────────────────────────────────────────────
# Kamida 32 ta random belgi: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_this_to_random_secret_key_min32chars

FLASK_ENV=production
FLASK_DEBUG=False

# Admin panel login (ALBATTA o'zgartiring!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=dtm_admin_2025

# ── Loyiha fayllari ────────────────────────────────────────────────────────────
# Excel faylni shu yerga qo'ying:
#   data/Fanlar_majmuasi_2025-2026.xlsx
# (data/ papkasi avtomatik yaratiladi: python scripts/manage.py init)
